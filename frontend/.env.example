# ==============================================================================
# EChat Frontend Configuration Template
# Duplicate this file as '.env' and fill in your credentials.
# ==============================================================================

# Supabase Configuration (Authentication and Database APIs)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key-here
DATABASE_URL=postgresql://postgres:your-db-password@db.your-project-id.supabase.co:5432/postgres
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here

# EmailJS Configuration (Used for sending OTP authentication emails)
EMAILJS_SERVICE_ID=service_your_service_id
EMAILJS_TEMPLATE_ID=template_your_template_id
EMAILJS_PUBLIC_KEY=your_public_key_here

# Zegocloud Configuration (Used for Audio/Video call features)
ZEGO_APP_ID=1234567890
ZEGO_APP_SIGN=your_zego_app_signature_here

# Backend Connection URL
BACKEND_URL=http://your-backend-ip-or-domain:3000

# Chat Message End-to-End Encryption Secret (Must be 32 characters or keys)
MESSAGE_ENCRYPTION_SECRET=ec_secure_secret_key_32_chars_here
