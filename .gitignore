frontend/build/
frontend/coverage/
frontend/app.*.symbols
frontend/app.*.map.json
frontend/android/app/debug
frontend/android/app/profile
frontend/android/app/release

# ==========================================
# BACKEND (Node.js / NestJS) Ignores
# ==========================================
backend/dist/
backend/node_modules/
backend/build/
backend/logs/
backend/*.log
backend/npm-debug.log*
backend/pnpm-debug.log*
backend/yarn-debug.log*
backend/yarn-error.log*
backend/lerna-debug.log*
backend/coverage/
backend/.nyc_output/
backend/.idea/
backend/.project
backend/.classpath
backend/.c9/
backend/*.launch
backend/.settings/
backend/*.sublime-workspace
backend/.env
backend/.env.development.local
backend/.env.test.local
backend/.env.production.local
backend/.env.local
backend/.temp/
backend/.tmp/
backend/pids/
backend/*.pid
backend/*.seed
backend/*.pid.lock
backend/report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json
