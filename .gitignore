*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/

# ==========================================
# FRONTEND (Flutter) Ignores
# ==========================================
frontend/.env
frontend/*.iml
frontend/*.ipr
frontend/*.iws
