# ==============================================================================
# EChat Backend Environment Configuration
# Copy this file to .env and fill in the values from your Supabase dashboard
# ==============================================================================

PORT=3000

# Supabase PostgreSQL database connection string
# Found in: Settings -> Database -> Connection string -> URI
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Supabase Auth JWT Secret for validating client tokens
# Found in: Settings -> API -> JWT Settings -> JWT Secret (reveal to copy)
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-value-here
